generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String
  isAdmin           Boolean   @default(false)
  emailVerified     Boolean   @default(false)
  verificationToken String?   @unique
  createdAt         DateTime  @default(now())
  products          Product[]
  conversations     Conversation[]
  messages          Message[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  address     String?
  latitude    Float?
  longitude   Float?
  image       String?
  images      String   @default("[]")
  city        String   @default("Messina")
  sold        Boolean  @default(false)
  status      String   @default("active")
  createdAt DateTime @default(now())
  seller      User     @relation(fields: [sellerId], references: [id])
  sellerId    String
  conversations Conversation[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("📦")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ThemeConfig {
  id        String   @id @default("default")
  primary   String   @default("#4f46e5")
  navFrom   String   @default("#312e81")
  navTo     String   @default("#4338ca")
  bgFrom    String   @default("#eef2ff")
  bgTo      String   @default("#f0fdf4")
  accent    String   @default("#4f46e5")
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  buyerId   String
  buyer     User      @relation(fields: [buyerId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([productId, buyerId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
}
